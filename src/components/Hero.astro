---
import GitHub from './icons/GitHub.astro';
import Arrow from './icons/Arrow.astro';
---

<section class="hero fade-in">
  <div class="container">
    <div class="hero-content">
      <span class="badge-live">v0.4.0 live on npm</span>

      <h1 class="hero-title">minimatch-fast</h1>

      <p class="narrative hero-subtitle">
        Drop-in replacement for minimatch.<br />
        Up to 17x faster. Zero vulnerabilities.
      </p>

      <div class="hero-install">
        <code class="install-command">npm install minimatch-fast</code>
        <button class="copy-btn" data-code="npm install minimatch-fast" aria-label="Copy install command">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
        </button>
      </div>

      <div class="hero-actions">
        <a href="#install" class="btn primary">
          Get Started
          <Arrow size={14} />
        </a>
        <a href="https://github.com/686f6c61/minimatch-fast" class="btn" target="_blank" rel="noopener noreferrer">
          <GitHub size={14} />
          GitHub
        </a>
      </div>

      <ul class="chips hero-chips">
        <li class="chip">picomatch engine</li>
        <li class="chip">100% API compatible</li>
        <li class="chip">TypeScript</li>
        <li class="chip">ESM + CJS</li>
        <li class="chip">402 tests</li>
      </ul>

      <p class="hero-license">
        <a href="https://github.com/686f6c61/minimatch-fast/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">
          MIT License
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-lg) 0;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .hero-title {
    margin-bottom: 0;
  }

  .hero-subtitle {
    margin-bottom: 0;
    color: var(--text);
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .6rem .8rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    max-width: 100%;
  }

  .install-command {
    font-size: .85rem;
    background: none;
    border: none;
    padding: 0;
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: .3rem;
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    color: var(--text-muted);
    transition: color .15s ease, border-color .15s ease;
    flex-shrink: 0;
  }

  .copy-btn:hover,
  .copy-btn.copied {
    color: var(--accent);
    border-color: var(--accent);
  }

  .hero-actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
  }

  .hero-chips {
    margin: 0;
  }

  .hero-license {
    margin-bottom: 0;
    font-size: .75rem;
  }
</style>

<script>
  document.querySelectorAll('.hero .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (code) {
        await navigator.clipboard.writeText(code);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      }
    });
  });
</script>
