---
const warmRows = [
  { scenario: 'Warm function API, {src,lib}/**/*.{js,ts,tsx}', fast: '29x faster', highlight: true },
  { scenario: 'Warm function API, @(foo|bar|baz).js', fast: '8.7x faster', highlight: true },
  { scenario: 'Warm function API, *.js / **/*.js', fast: '3-3.3x faster', highlight: true },
];

const engineRows = [
  { scenario: 'Pre-compiled engine, file[0-9].js', fast: '6.2x faster', highlight: true },
  { scenario: 'Pre-compiled engine, @(foo|bar|baz).js', fast: '3.6x faster', highlight: true },
  { scenario: 'Pre-compiled engine, {src,lib}/**/*.{js,ts,tsx}', fast: '3.4x faster', highlight: true },
  { scenario: 'Pre-compiled engine, *.js / **/*.js', fast: '2.6x faster', highlight: true },
  { scenario: 'Pre-compiled engine, {src,lib}/*.js (2-way brace)', fast: '0.65x (slower)', highlight: false },
  { scenario: 'Cold single calls (every call compiles)', fast: 'parity to 2.3x', highlight: false },
];

const securityComparison = [
  { feature: 'CVE-2022-3517 (ReDoS)', minimatch: 'Vulnerable', fast: 'Not affected', danger: true },
  { feature: 'Pattern {1..1000}', minimatch: 'Freezes', fast: 'Instant', danger: true },
  { feature: 'Brace expansion limit', minimatch: 'None', fast: '10,000 max', danger: false },
];
---

<section class="fade-in" id="benchmarks">
  <div class="container">
    <div class="section-header">
      <span class="cmd">benchmark</span>
      <h2>Performance Benchmarks</h2>
      <p>Honest measurements vs minimatch v10.x — median of 15 rounds, A/B/B/A interleaved, 1000-path deterministic corpus</p>
    </div>

    <h3 class="table-heading">Real-world globbing (LRU cache)</h3>
    <p class="table-note">
      Build tools and linters match the same patterns against thousands of files.
      minimatch recompiles on every call; minimatch-fast caches compiled patterns.
    </p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Scenario</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {warmRows.map(row => (
            <tr>
              <td><code>{row.scenario}</code></td>
              <td>Baseline</td>
              <td class="fast-cell"><span class={row.highlight ? 'badge' : ''}>{row.fast}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="table-heading">Engine vs engine (no cache)</h3>
    <p class="table-note">
      Pre-compiled instances on both sides. Brace patterns compile natively into a
      single regex and multiple expansions share one matcher, winning 2-6x on most
      shapes. The one remaining slower case is the simple 2-way brace, where
      minimatch's regex is unusually efficient (~150ns per call in absolute terms).
    </p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Scenario</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {engineRows.map(row => (
            <tr>
              <td><code>{row.scenario}</code></td>
              <td>Baseline</td>
              <td class="fast-cell"><span class={row.highlight ? 'badge' : ''}>{row.fast}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="table-heading">Security Comparison</h3>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Feature</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {securityComparison.map(row => (
            <tr>
              <td>{row.feature}</td>
              <td class={row.danger ? 'danger' : ''}>{row.minimatch}</td>
              <td class="fast-cell"><span class="badge">{row.fast}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="benchmark-note">
      Node.js 22, Linux. Reproduce with <code>npm run benchmark</code> — it prints
      the full environment and all four scenarios.
    </p>
  </div>
</section>

<style>
  .table-heading {
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
    font-size: .95rem;
  }

  .table-note {
    font-size: .78rem;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .danger {
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .benchmark-note {
    font-size: .72rem;
    color: var(--text-muted);
    margin-top: 1rem;
    margin-bottom: 0;
  }
</style>
