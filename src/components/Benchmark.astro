---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).benchmark;
---

<section class="fade-in" id="benchmarks">
  <div class="container">
    <div class="section-header">
      <span class="cmd">benchmark</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <h3 class="table-heading">{t.warm.heading}</h3>
    <p class="table-note">
      {t.warm.note}
    </p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.pattern}</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
            <th>{t.cols.speedup}</th>
          </tr>
        </thead>
        <tbody>
          {t.warm.rows.map(row => (
            <tr>
              <td><code>{row.scenario}</code></td>
              <td>{row.minimatch}</td>
              <td>{row.fast}</td>
              <td class="fast-cell"><span class={row.highlight ? 'badge' : ''}>{row.speedup}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">
      {t.warm.earlyRejection}
    </p>

    <h3 class="table-heading">{t.engine.heading}</h3>
    <p class="table-note">
      {t.engine.note}
    </p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.pattern}</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {t.engine.rows.map(row => (
            <tr>
              <td><code>{row.scenario}</code></td>
              <td>{t.baseline}</td>
              <td class="fast-cell"><span class={row.highlight ? 'badge' : ''}>{row.speedup}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="table-heading">{t.compileCold.heading}</h3>
    <p class="table-note">
      {t.compileCold.note}
    </p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.scenario}</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {t.compileCold.rows.map(row => (
            <tr>
              <td><code>{row.scenario}</code></td>
              <td>{t.baseline}</td>
              <td class="fast-cell"><span class={row.highlight ? 'badge' : ''}>{row.speedup}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="table-heading">{t.security.heading}</h3>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.security.featureCol}</th>
            <th>minimatch</th>
            <th>minimatch-fast</th>
          </tr>
        </thead>
        <tbody>
          {t.security.rows.map(row => (
            <tr>
              <td>{row.feature}</td>
              <td class={row.danger ? 'danger' : ''}>{row.minimatch}</td>
              <td class="fast-cell"><span class="badge">{row.fast}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="benchmark-note">
      {t.note} <code>npm run benchmark</code>.
    </p>
  </div>
</section>

<style>
  .table-heading {
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
    font-size: .95rem;
  }

  .table-note {
    font-size: .78rem;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .danger {
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .benchmark-note {
    font-size: .72rem;
    color: var(--text-muted);
    margin-top: 1rem;
    margin-bottom: 0;
  }
</style>
