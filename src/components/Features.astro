---
import Speed from './icons/Speed.astro';
import Shield from './icons/Shield.astro';
import Stable from './icons/Stable.astro';
import Check from './icons/Check.astro';
import TypeScriptIcon from './icons/TypeScript.astro';
import Package from './icons/Package.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).features;

const icons = [Speed, Shield, Stable, Check, TypeScriptIcon, Package];

const features = t.items.map((item, i) => ({ ...item, icon: icons[i] }));
---

<section class="fade-in" id="features">
  <div class="container">
    <div class="section-header">
      <span class="cmd">features</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="card-grid">
      {features.map(feature => (
        <div class="card feature-card">
          <div class="feature-icon">
            <feature.icon size={20} />
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-bottom: 1rem;
    color: var(--accent);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
  }

  .feature-title {
    font-size: .95rem;
    margin-bottom: .5rem;
  }

  .feature-description {
    color: var(--text-muted);
    font-size: .8rem;
    margin-bottom: 0;
    line-height: 1.6;
  }
</style>
