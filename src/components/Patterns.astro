---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).patterns;
---

<section class="fade-in" id="patterns">
  <div class="container-wide">
    <div class="section-header">
      <span class="cmd">patterns</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.pattern}</th>
            <th>{t.cols.description}</th>
            <th>{t.cols.example}</th>
          </tr>
        </thead>
        <tbody>
          {t.patterns.map(p => (
            <tr>
              <td><code>{p.pattern}</code></td>
              <td>{p.description}</td>
              <td class="example-cell"><code>{p.example}</code></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="subsection">
      <h3>{t.posixHeading}</h3>
      <p class="subsection-desc">{t.posixSub}</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>{t.cols.class}</th>
              <th>{t.cols.description}</th>
              <th>{t.cols.example}</th>
            </tr>
          </thead>
          <tbody>
            {t.posixClasses.map(p => (
              <tr>
                <td><code>{p.pattern}</code></td>
                <td>{p.description}</td>
                <td class="example-cell"><code>{p.example}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="subsection">
      <h3>{t.unicodeHeading}</h3>
      <p class="subsection-desc">{t.unicodeSub}</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>{t.cols.pattern}</th>
              <th>{t.cols.description}</th>
              <th>{t.cols.matches}</th>
            </tr>
          </thead>
          <tbody>
            {t.unicodeExamples.map(p => (
              <tr>
                <td><code>{p.pattern}</code></td>
                <td>{p.description}</td>
                <td class="example-cell"><code>{p.example}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .table-wrapper table { min-width: 720px; }

  .example-cell code {
    font-size: .72rem;
    white-space: nowrap;
  }

  .subsection { margin-top: var(--space-md); }

  .subsection h3 { font-size: .95rem; margin-bottom: .25rem; }

  .subsection-desc {
    color: var(--text-muted);
    font-size: .78rem;
    margin-bottom: 1rem;
  }
</style>
