---
import CodeBlock from './CodeBlock.astro';
import Arrow from './icons/Arrow.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).api;

const examples = [
  `minimatch('foo.js', '*.js'); // true
minimatch('foo/bar.js', '**/*.js'); // true`,
  `const files = ['a.js', 'b.ts', 'c.js'];
minimatch.match(files, '*.js');
// => ['a.js', 'c.js']`,
  `const isJS = minimatch.filter('*.js');
['a.js', 'b.ts'].filter(isJS);
// => ['a.js']`,
  `minimatch.makeRe('*.js');
// => /^(?:(?!\\.)...)\\.js$/`,
  `minimatch.braceExpand('{a,b}{1,2}');
// => ['a1', 'a2', 'b1', 'b2']`,
  `minimatch.escape('[foo].js');
// => '\\\\[foo\\\\].js'`,
  `minimatch.unescape('\\\\[foo\\\\].js');
// => '[foo].js'`,
  `const mm = minimatch.defaults({ nocase: true });
mm('FOO.js', '*.js'); // true`,
  `const mm = new Minimatch('**/*.js');
mm.match('src/foo.js'); // true
mm.match('test/bar.js'); // true`,
];

const apiMethods = t.methods.map((method, i) => ({ ...method, example: examples[i] }));
---

<section class="fade-in" id="api">
  <div class="container">
    <div class="section-header">
      <span class="cmd">api</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="api-list">
      {apiMethods.map((method, index) => (
        <details class="api-item" id={`api-${index}`}>
          <summary class="api-summary">
            <code class="api-name">{method.name}</code>
            <Arrow size={14} direction="down" class="api-arrow" />
          </summary>
          <div class="api-content">
            <p class="api-description">{method.description}</p>

            <h4>{t.params}</h4>
            <ul class="api-params list-minimal">
              {method.params.map(param => (
                <li>
                  <code>{param.name}</code>
                  <span class="param-type">{param.type}</span>
                  <span class="param-desc">{param.desc}</span>
                </li>
              ))}
            </ul>

            <h4>{t.returns}</h4>
            <p><code>{method.returns}</code></p>

            <h4>{t.example}</h4>
            <CodeBlock lang="javascript" code={method.example} showCopy={false} locale={lang} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .api-list {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .api-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color .2s ease;
  }

  .api-item:hover { border-color: var(--accent); }

  .api-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: .8rem 1.25rem;
    cursor: pointer;
    list-style: none;
  }

  .api-summary::-webkit-details-marker { display: none; }

  .api-name {
    font-size: .8rem;
    background: none;
    border: none;
    padding: 0;
  }

  .api-arrow {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: transform .2s ease;
  }

  details[open] .api-arrow { transform: rotate(180deg); }

  .api-content {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid var(--border);
  }

  .api-description {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: .8rem;
  }

  .api-content h4 {
    font-size: .68rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: .5rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .api-params li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: .5rem;
  }

  .param-type {
    font-family: var(--font-mono);
    font-size: .68rem;
    color: var(--accent);
  }

  .param-desc {
    color: var(--text-muted);
    font-size: .75rem;
  }
</style>
