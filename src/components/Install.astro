---
import CodeBlock from './CodeBlock.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).install;
---

<section class="fade-in" id="install">
  <div class="container">
    <div class="section-header">
      <span class="cmd">install</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="install-grid">
      <div class="card install-option">
        <h3><span class="badge">{t.option1Badge}</span> {t.option1Title}</h3>
        <p>{t.option1Intro}</p>

        <CodeBlock
          lang="bash"
          title="Terminal"
          locale={lang}
          code={`npm uninstall minimatch
npm install minimatch-fast`}
        />

        <p>{t.option1Then}</p>

        <div class="diff-block">
          <pre><code><span class="diff-remove">- const minimatch = require('minimatch');</span>
<span class="diff-add">+ const minimatch = require('minimatch-fast');</span></code></pre>
        </div>

        <div class="diff-block">
          <pre><code><span class="diff-remove">- import minimatch from 'minimatch';</span>
<span class="diff-add">+ import minimatch from 'minimatch-fast';</span></code></pre>
        </div>
      </div>

      <div class="card install-option">
        <h3><span class="badge">{t.option2Badge}</span> {t.option2Title}</h3>
        <p>{t.option2Intro}</p>

        <CodeBlock
          lang="bash"
          title="Terminal"
          locale={lang}
          code="npm install minimatch@npm:minimatch-fast"
        />

        <p>{t.option2DetailPre} <code>minimatch</code>{t.option2DetailPost}</p>

        <div class="alias-note">
          <strong>{t.option2NoteStrong}</strong> {t.option2Note}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .install-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .install-option h3 {
    display: flex;
    align-items: center;
    gap: .6rem;
    font-size: .95rem;
    margin-bottom: 1rem;
  }

  .install-option p {
    font-size: .8rem;
    color: var(--text-muted);
  }

  .diff-block {
    margin-bottom: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .diff-block pre {
    margin: 0;
    border: none;
    border-radius: 0;
    overflow-x: auto;
  }

  .diff-remove {
    display: block;
    background: #fee2;
    color: #c0392b;
    margin: -.1rem -1rem;
    padding: .1rem 1rem;
  }

  .diff-add {
    display: block;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    margin: -.1rem -1rem;
    padding: .1rem 1rem;
  }

  .alias-note {
    padding: .8rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: .75rem;
    color: var(--text-muted);
  }

  .alias-note strong { color: var(--text); }

  @media (max-width: 768px) {
    .install-grid { grid-template-columns: 1fr; }
  }
</style>
