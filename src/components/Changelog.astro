---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).changelog;

const versions = t.versions;
const typeLabels: Record<string, string> = t.typeLabels;
---

<section class="fade-in" id="changelog">
  <div class="container">
    <div class="section-header">
      <span class="cmd">changelog</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="timeline">
      {versions.map((v, index) => (
        <div class="timeline-item">
          <div class="timeline-marker">
            <div class="timeline-dot" />
            {index < versions.length - 1 && <div class="timeline-line" />}
          </div>

          <div class="timeline-content">
            <div class="version-header">
              <div class="version-info">
                <span class="version-number">v{v.version}</span>
                {v.tag && <span class="badge">{v.tag}</span>}
              </div>
              <span class="version-date">{v.date}</span>
            </div>

            {v.performance && (
              <div class="version-performance">
                <strong>{v.performance}</strong>
              </div>
            )}

            <ul class="chips version-highlights">
              {v.highlights.map(h => (
                <li class="chip">{h}</li>
              ))}
            </ul>

            <ul class="version-changes list-minimal">
              {v.changes.map(change => (
                <li class={`change-${change.type}`}>
                  <span class="change-type">{typeLabels[change.type]}</span>
                  <span class="change-text">{change.text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-item {
    display: flex;
    gap: 1.25rem;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    margin-top: .45rem;
    background: var(--accent);
    border-radius: 50%;
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--border);
    margin-top: .5rem;
  }

  .timeline-content {
    flex: 1;
    padding-bottom: var(--space-lg);
  }

  .timeline-item:last-child .timeline-content { padding-bottom: 0; }

  .version-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: .5rem;
    margin-bottom: .75rem;
  }

  .version-info {
    display: flex;
    align-items: center;
    gap: .6rem;
  }

  .version-number {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .version-date {
    font-size: .72rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .version-performance {
    display: inline-block;
    margin-bottom: .75rem;
    padding: .2rem .6rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    font-size: .72rem;
    color: var(--accent);
  }

  .version-highlights { margin-bottom: .75rem; }

  .version-changes li {
    display: flex;
    align-items: flex-start;
    gap: .6rem;
    font-size: .75rem;
    color: var(--text-muted);
  }

  .change-type {
    flex-shrink: 0;
    padding: 0 .4em;
    font-size: .6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    border-radius: 2px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    line-height: 1.9;
  }

  .change-added .change-type,
  .change-security .change-type {
    background: var(--text);
    border-color: var(--text);
    color: var(--bg);
  }

  @media (max-width: 768px) {
    .timeline-item { gap: .75rem; }
  }
</style>
