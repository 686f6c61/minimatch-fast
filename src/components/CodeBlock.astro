---
interface Props {
  code: string;
  lang?: string;
  title?: string;
  showCopy?: boolean;
}

const { code, lang = 'javascript', title, showCopy = true } = Astro.props;
---

<div class="code-block">
  {title && <div class="code-block-header">{title}</div>}
  <div class="code-block-content">
    <pre><code class={`language-${lang}`}>{code.trim()}</code></pre>
    {showCopy && (
      <button class="copy-btn" data-code={code.trim()} aria-label="Copy code">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span class="copy-text">copy</span>
      </button>
    )}
  </div>
</div>

<style>
  .code-block {
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--card-bg);
  }

  .code-block-header {
    padding: .4rem .8rem;
    font-size: .68rem;
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
  }

  .code-block-content {
    position: relative;
  }

  .code-block pre {
    margin: 0;
    padding: 1rem;
    border: none;
    border-radius: 0;
    background: var(--card-bg);
  }

  .copy-btn {
    position: absolute;
    top: .5rem;
    right: .5rem;
    display: flex;
    align-items: center;
    gap: .3rem;
    padding: .3rem .5rem;
    font-size: .68rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: color .15s ease, border-color .15s ease;
  }

  .copy-btn:hover,
  .copy-btn.copied {
    color: var(--accent);
    border-color: var(--accent);
  }

  .copy-btn.copied .copy-text { display: none; }
  .copy-btn.copied::after { content: 'copied!'; }
</style>

<script>
  document.querySelectorAll('.code-block .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (code) {
        await navigator.clipboard.writeText(code);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      }
    });
  });
</script>
