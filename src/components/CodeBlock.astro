---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  code: string;
  lang?: string;
  locale?: Lang;
  title?: string;
  showCopy?: boolean;
}

const { code, lang = 'javascript', locale = 'es', title, showCopy = true } = Astro.props;
const t = useTranslations(locale).codeBlock;
---

<div class="code-block">
  {(title || showCopy) && (
    <div class="code-block-header">
      <span class="code-block-label">{title ?? lang}</span>
      {showCopy && (
        <button class="copy-btn" data-code={code.trim()} aria-label={t.copyAria}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
          <span class="copy-text">{t.copy}</span>
          <span class="copied-text">{t.copied}</span>
        </button>
      )}
    </div>
  )}
  <pre><code class={`language-${lang}`}>{code.trim()}</code></pre>
</div>

<style>
  .code-block {
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--card-bg);
  }

  /* Header row: language/title label on the left, copy button on the right.
     The button lives here (not absolutely positioned over the code), so it
     can never overlap the text. */
  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    padding: .3rem .5rem .3rem .8rem;
    border-bottom: 1px solid var(--border);
  }

  .code-block-label {
    font-size: .68rem;
    font-weight: 600;
    color: var(--text-muted);
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .code-block pre {
    margin: 0;
    padding: 1rem;
    border: none;
    border-radius: 0;
    background: var(--card-bg);
    overflow-x: auto;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    gap: .3rem;
    padding: .25rem .5rem;
    font-size: .68rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: color .15s ease, border-color .15s ease;
    flex-shrink: 0;
  }

  .copy-btn:hover,
  .copy-btn.copied {
    color: var(--accent);
    border-color: var(--accent);
  }

  .copy-btn .copied-text { display: none; }
  .copy-btn.copied .copy-text { display: none; }
  .copy-btn.copied .copied-text { display: inline; }
</style>

<script>
  document.querySelectorAll('.code-block .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (code) {
        await navigator.clipboard.writeText(code);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      }
    });
  });
</script>
