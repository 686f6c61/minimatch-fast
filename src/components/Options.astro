---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).options;
---

<section class="fade-in" id="options">
  <div class="container-wide">
    <div class="section-header">
      <span class="cmd">options</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <h3>{t.coreHeading} <span class="chip">{t.coreBadge}</span></h3>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.option}</th>
            <th>{t.cols.type}</th>
            <th>{t.cols.default}</th>
            <th>{t.cols.description}</th>
          </tr>
        </thead>
        <tbody>
          {t.core.map(opt => (
            <tr>
              <td><code>{opt.name}</code></td>
              <td class="type-cell"><code>{opt.type}</code></td>
              <td class="default-cell"><code>{opt.default}</code></td>
              <td class="desc-cell">{opt.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3>{t.extendedHeading} <span class="badge">{t.extendedBadge}</span></h3>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.option}</th>
            <th>{t.cols.type}</th>
            <th>{t.cols.default}</th>
            <th>{t.cols.description}</th>
          </tr>
        </thead>
        <tbody>
          {t.extended.map(opt => (
            <tr>
              <td><code>{opt.name}</code></td>
              <td class="type-cell"><code>{opt.type}</code></td>
              <td class="default-cell"><code>{opt.default}</code></td>
              <td class="desc-cell">{opt.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3>{t.callbackHeading} <span class="badge">{t.callbackBadge}</span></h3>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>{t.cols.option}</th>
            <th>{t.cols.type}</th>
            <th>{t.cols.default}</th>
            <th>{t.cols.description}</th>
          </tr>
        </thead>
        <tbody>
          {t.callbacks.map(opt => (
            <tr>
              <td><code>{opt.name}</code></td>
              <td class="type-cell"><code>{opt.type}</code></td>
              <td class="default-cell"><code>{opt.default}</code></td>
              <td class="desc-cell">{opt.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3>{t.examplesHeading}</h3>
    <div class="examples-grid">
      <div class="card example-card">
        <h4>ignore</h4>
        <pre><code>const mm = new Minimatch('**/*.js', {'{'}
  ignore: ['**/*.test.js', '**/node_modules/**']
{'}'});
mm.match('src/app.js');      // true
mm.match('src/app.test.js'); // false</code></pre>
      </div>

      <div class="card example-card">
        <h4>failglob</h4>
        <pre><code>// Throw if no matches found
minimatch.match(files, '*.ts', {'{'} failglob: true {'}'});
// Error: No matches found for pattern: *.ts</code></pre>
      </div>

      <div class="card example-card">
        <h4>contains</h4>
        <pre><code>// Match anywhere in string
minimatch('foobar', 'bar', {'{'} contains: true {'}'});
// true (matches substring)</code></pre>
      </div>

      <div class="card example-card">
        <h4>format</h4>
        <pre><code>// Transform paths before matching
const mm = new Minimatch('src/*.js', {'{'}
  format: (s) => s.replace(/^\.\//, '')
{'}'});
mm.match('./src/app.js'); // true</code></pre>
      </div>

      <div class="card example-card">
        <h4>callbacks</h4>
        <pre><code>const mm = new Minimatch('*.js', {'{'}
  onMatch: (r) => console.log('Match:', r.output),
  onResult: (r) => stats[r.isMatch ? 'hits' : 'miss']++
{'}'});</code></pre>
      </div>

      <div class="card example-card">
        <h4>literalBrackets</h4>
        <pre><code>// Match literal brackets in filenames
const mm = new Minimatch('[file].js', {'{'}
  literalBrackets: true
{'}'});
mm.match('[file].js'); // true</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  h3 {
    display: flex;
    align-items: center;
    gap: .6rem;
    flex-wrap: wrap;
    margin-top: var(--space-md);
    margin-bottom: .75rem;
    font-size: .95rem;
  }

  section .section-header + h3 { margin-top: 0; }

  .table-wrapper { margin-bottom: 1.5rem; }
  .table-wrapper table { min-width: 860px; }

  .type-cell, .default-cell { white-space: nowrap; }

  .type-cell code, .default-cell code { font-size: .68rem; }

  .desc-cell {
    font-size: .75rem;
    color: var(--text-muted);
  }

  .examples-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .example-card { padding: 1.25rem; }

  .example-card h4 {
    font-family: var(--font-mono);
    font-size: .78rem;
    margin-bottom: .75rem;
    color: var(--accent);
  }

  .example-card pre {
    margin: 0;
    font-size: .7rem;
    border: none;
    padding: 0;
    background: transparent;
  }
</style>
