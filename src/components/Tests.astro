---
import CodeBlock from './CodeBlock.astro';

const testCategories = [
  { name: 'Unit Tests', count: 42, description: 'Core functionality tests' },
  { name: 'Compatibility Tests', count: 196, description: 'Behavior parity with minimatch' },
  { name: 'Edge Case Tests', count: 64, description: 'Windows paths, extended options, dotfiles' },
  { name: 'Security Tests', count: 23, description: 'CVE-2022-3517 and input validation tests' },
  { name: 'Verification Tests', count: 53, description: 'POSIX classes, Unicode, regex edge cases' },
  { name: 'Regression Tests', count: 24, description: 'Cache correctness, hasMagic, makeRe, escape alignment' },
];

const runTests = `# Run all tests
npm test

# Run with coverage
npm run test:coverage

# Run compatibility tests only
npm run test:compat`;
---

<section class="fade-in" id="tests">
  <div class="container">
    <div class="section-header">
      <span class="cmd">tests</span>
      <h2>Testing & Compatibility</h2>
      <p>Comprehensive test suite ensures reliability</p>
    </div>

    <div class="test-grid">
      {testCategories.map(cat => (
        <div class="card test-card">
          <div class="test-count">{cat.count}</div>
          <div class="test-name">{cat.name}</div>
          <div class="test-desc">{cat.description}</div>
        </div>
      ))}
    </div>

    <div class="card test-details">
      <h3><span class="badge">402 tests total</span></h3>
      <p>
        Every release is verified against the original minimatch test suite plus
        additional tests for edge cases, Windows paths, and security vulnerabilities.
      </p>

      <h3>Running Tests</h3>
      <CodeBlock lang="bash" code={runTests} />

      <h3>Reporting Issues</h3>
      <p>
        Found a compatibility issue? Please open an issue on GitHub with:
      </p>
      <ul class="list-minimal">
        <li>The pattern and path that produces different results</li>
        <li>Expected behavior (what minimatch returns)</li>
        <li>Actual behavior (what minimatch-fast returns)</li>
        <li>Any relevant options used</li>
      </ul>
      <p class="issue-link">
        <a href="https://github.com/686f6c61/minimatch-fast/issues" target="_blank" rel="noopener noreferrer">
          Open an issue on GitHub
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .test-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .test-card { padding: 1.25rem; }

  .test-count {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: .4rem;
    color: var(--accent);
  }

  .test-name {
    font-weight: 600;
    font-size: .8rem;
    margin-bottom: .25rem;
  }

  .test-desc {
    font-size: .72rem;
    color: var(--text-muted);
  }

  .test-details h3 {
    font-size: .95rem;
    margin-top: 1.5rem;
    margin-bottom: .75rem;
  }

  .test-details h3:first-child { margin-top: 0; }

  .test-details p {
    color: var(--text-muted);
    font-size: .8rem;
    line-height: 1.6;
  }

  .test-details .list-minimal {
    margin: .75rem 0 1rem;
  }

  .test-details .list-minimal li {
    color: var(--text-muted);
    font-size: .8rem;
  }

  .issue-link { margin-bottom: 0; }
</style>
