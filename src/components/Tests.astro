---
import CodeBlock from './CodeBlock.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).tests;

const testCategories = t.categories;

const runTests = `# Run all tests
npm test

# Run with coverage
npm run test:coverage

# Run compatibility tests only
npm run test:compat`;
---

<section class="fade-in" id="tests">
  <div class="container">
    <div class="section-header">
      <span class="cmd">tests</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="test-grid">
      {testCategories.map(cat => (
        <div class="card test-card">
          <div class="test-count">{cat.count}</div>
          <div class="test-name">{cat.name}</div>
          <div class="test-desc">{cat.description}</div>
        </div>
      ))}
    </div>

    <div class="card test-details">
      <h3><span class="badge">{t.totalBadge}</span></h3>
      <p>
        {t.totalText}
      </p>

      <h3>{t.runHeading}</h3>
      <CodeBlock lang="bash" code={runTests} locale={lang} />

      <h3>{t.reportHeading}</h3>
      <p>
        {t.reportIntro}
      </p>
      <ul class="list-minimal">
        {t.reportItems.map(item => (
          <li>{item}</li>
        ))}
      </ul>
      <p class="issue-link">
        <a href="https://github.com/686f6c61/minimatch-fast/issues" target="_blank" rel="noopener noreferrer">
          {t.reportLink}
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .test-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .test-card { padding: 1.25rem; }

  .test-count {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: .4rem;
    color: var(--accent);
  }

  .test-name {
    font-weight: 600;
    font-size: .8rem;
    margin-bottom: .25rem;
  }

  .test-desc {
    font-size: .72rem;
    color: var(--text-muted);
  }

  .test-details h3 {
    font-size: .95rem;
    margin-top: 1.5rem;
    margin-bottom: .75rem;
  }

  .test-details h3:first-child { margin-top: 0; }

  .test-details p {
    color: var(--text-muted);
    font-size: .8rem;
    line-height: 1.6;
  }

  .test-details .list-minimal {
    margin: .75rem 0 1rem;
  }

  .test-details .list-minimal li {
    color: var(--text-muted);
    font-size: .8rem;
  }

  .issue-link { margin-bottom: 0; }
</style>
