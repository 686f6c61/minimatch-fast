---
import Shield from './icons/Shield.astro';
import CodeBlock from './CodeBlock.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).security;

const vulnerablePattern = `// CVE-2022-3517 - Vulnerable pattern in minimatch
// This causes catastrophic backtracking (ReDoS)
const pattern = '[!' + 'a'.repeat(50000) + ']';

// In minimatch: hangs for minutes or crashes
minimatch('test', pattern);

// In minimatch-fast: instant, no vulnerability
minimatch('test', pattern); // false, returns immediately`;

const braceExample = `// Dangerous brace expansion in minimatch
// This creates 1,000,000 patterns and freezes

const pattern = '{1..1000000}';
minimatch.braceExpand(pattern); // Hangs

// In minimatch-fast: limited to 10,000 max
// Returns original pattern if limit exceeded`;

const inputValidation = `// minimatch-fast validates input types
// Prevents runtime errors and unexpected behavior

minimatch(null, '*.js');      // TypeError: path must be a string
minimatch('test', undefined); // TypeError: glob pattern must be a string
minimatch(123, '*.js');       // TypeError: path must be a string

// Pattern length limits prevent DoS
const veryLong = 'a'.repeat(100000);
minimatch('test', veryLong);  // TypeError: pattern too long`;
---

<section class="fade-in" id="security">
  <div class="container">
    <div class="section-header">
      <span class="cmd">security</span>
      <h2>{t.heading}</h2>
      <p>{t.sub}</p>
    </div>

    <div class="security-grid">
      <div class="card security-card">
        <div class="security-icon">
          <Shield size={20} />
        </div>
        <h3>{t.cve.title}</h3>
        <p>
          {t.cve.p1}
        </p>
        <p>
          {t.cve.p2}
        </p>
        <CodeBlock lang="javascript" code={vulnerablePattern} locale={lang} />
      </div>

      <div class="card security-card">
        <div class="security-icon">
          <Shield size={20} />
        </div>
        <h3>{t.brace.title}</h3>
        <p>
          {t.brace.p1Pre} <code>{`{1..1000000}`}</code> {t.brace.p1Post}
        </p>
        <p>
          {t.brace.p2}
        </p>
        <CodeBlock lang="javascript" code={braceExample} locale={lang} />
      </div>

      <div class="card security-card">
        <div class="security-icon">
          <Shield size={20} />
        </div>
        <h3>{t.input.title}</h3>
        <p>
          {t.input.p1}
        </p>
        <p>
          {t.input.p2}
        </p>
        <CodeBlock lang="javascript" code={inputValidation} locale={lang} />
      </div>
    </div>

    <div class="card security-summary">
      <h3>{t.summary.title}</h3>
      <ul class="list-minimal">
        {t.summary.items.map(item => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .security-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .security-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-bottom: 1rem;
    color: var(--accent);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
  }

  .security-card h3 {
    font-size: .95rem;
    margin-bottom: .75rem;
  }

  .security-card p {
    color: var(--text-muted);
    font-size: .8rem;
    line-height: 1.6;
  }

  .security-card .code-block { margin-bottom: 0; }

  .security-summary h3 {
    font-size: .95rem;
    margin-bottom: .5rem;
  }

  .security-summary li {
    color: var(--text-muted);
    font-size: .8rem;
  }
</style>
