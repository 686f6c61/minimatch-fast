---
import GitHub from './icons/GitHub.astro';
import Npm from './icons/Npm.astro';
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang).footer;

const links = [
  { href: 'https://www.npmjs.com/package/minimatch-fast', label: 'npm', icon: Npm },
  { href: 'https://github.com/686f6c61/minimatch-fast', label: 'GitHub', icon: GitHub },
  { href: 'https://x.com/686f6c61', label: 'X (Twitter)', icon: null },
  { href: 'https://github.com/686f6c61/minimatch-fast/issues', label: 'Issues', icon: null },
  { href: 'https://github.com/686f6c61/minimatch-fast/blob/main/LICENSE', label: t.mitLabel, icon: null },
];

const credits = [
  { name: 'Isaac Z. Schlueter', project: 'minimatch', url: 'https://github.com/isaacs/minimatch' },
  { name: 'Jon Schlinkert', project: 'picomatch', url: 'https://github.com/micromatch/picomatch' },
  { name: 'Jon Schlinkert', project: 'braces', url: 'https://github.com/micromatch/braces' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="cmd">minimatch-fast</span>
        <p class="footer-tagline">
          {t.tagline1}<br />
          {t.tagline2}
        </p>
      </div>

      <div class="footer-links">
        <h4>{t.linksHeading}</h4>
        <ul class="list-minimal">
          {links.map(link => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.icon && <link.icon size={14} />}
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-credits">
        <h4>{t.creditsHeading}</h4>
        <ul class="list-minimal">
          {credits.map(credit => (
            <li>
              <a href={credit.url} target="_blank" rel="noopener noreferrer">
                {credit.name}
              </a>
              <span class="credit-project">({credit.project})</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        {t.bottom} <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-lg) 0 var(--space-md);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: .78rem;
    line-height: 1.6;
    margin-bottom: 0;
  }

  .footer h4 {
    font-size: .68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--text-muted);
    margin-bottom: .5rem;
  }

  .footer li { padding: .35rem 0; }

  .footer a {
    font-size: .78rem;
    display: inline-flex;
    align-items: center;
    gap: .4rem;
  }

  .credit-project {
    color: var(--text-muted);
    font-size: .68rem;
    margin-left: .25rem;
  }

  .footer-bottom {
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
  }

  .footer-bottom p {
    color: var(--text-muted);
    font-size: .72rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }
  }
</style>
